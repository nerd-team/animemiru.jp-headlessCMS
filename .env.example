# Database
DATABASE_URL=mongodb://127.0.0.1/animemiru

# Payload
PAYLOAD_SECRET=change-me-to-random-32chars-min
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PREVIEW_SECRET=change-me-preview-secret
CRON_SECRET=change-me-cron-secret

# WordPress 移行
WP_URL=https://animemiru.jp
WP_MIGRATE_LIMIT=50
WP_MIGRATE_PAGE=1
WP_MIGRATE_IMAGES=true

# SEO
NEXT_PUBLIC_OG_IMAGE=https://animemiru.jp/wp-content/img/ogp_top.jpg

# 編集者アカウント（開発用シード。本番は強力なパスワードに変更）
EDITOR_PASSWORD_SHOGO=
EDITOR_PASSWORD_FACTORY=

# 本番でアクセス数トラッキングを有効化（/next/view）
ENABLE_VIEW_TRACKING=true
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=
NEXT_PUBLIC_DYSHORTS_ID=
