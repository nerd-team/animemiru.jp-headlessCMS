{
  "name": "animemiru.jp-headlessCMS",
  "version": "1.0.0",
  "description": "アニメミル - Payload CMS + Next.js headless",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "node scripts/dev.mjs",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "postinstall": "npm run generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "seed:demo": "node scripts/seed-demo.mjs",
    "migrate:wp": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/wp-migrate.ts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.85.2",
    "@payloadcms/db-mongodb": "3.85.2",
    "@payloadcms/live-preview-react": "3.85.2",
    "@payloadcms/next": "3.85.2",
    "@payloadcms/plugin-form-builder": "3.85.2",
    "@payloadcms/plugin-nested-docs": "3.85.2",
    "@payloadcms/plugin-redirects": "3.85.2",
    "@payloadcms/plugin-search": "3.85.2",
    "@payloadcms/plugin-seo": "3.85.2",
    "@payloadcms/richtext-lexical": "3.85.2",
    "@payloadcms/ui": "3.85.2",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "15.2.4",
    "next-sitemap": "^4.2.3",
    "payload": "3.85.2",
    "prism-react-renderer": "^2.3.1",
    "react": "19.0.1",
    "react-dom": "19.0.1",
    "react-hook-form": "7.54.2",
    "react-slick": "^0.30.3",
    "sharp": "0.34.2",
    "slick-carousel": "^1.8.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "@types/react-slick": "^0.23.13",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.2.4",
    "mongodb-memory-server": "^11.2.0",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.19.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
